# ─────────────────────────────────────────────────────────────────────────────
# AreBet — environment variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Project URL — safe to expose (used in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — safe to expose (protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY, never prefix with NEXT_PUBLIC_
# Required for: signal recording, outcome resolution, admin backfill
# Found in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# ── API-Football (optional) ───────────────────────────────────────────────────
# Register at https://api-sports.io → free tier = 100 req/day
# If unset, the app runs in demo mode with simulated match data.
API_FOOTBALL_KEY=

# ── Data mode ─────────────────────────────────────────────────────────────────
# Force demo mode regardless of whether API_FOOTBALL_KEY is set.
# Set to "false" in production with a real API key.
NEXT_PUBLIC_USE_DEMO_DATA=true

# ── Admin operations ──────────────────────────────────────────────────────────
# Protects the POST /api/signals/backfill route.
# Set to any strong random string, e.g.: openssl rand -hex 32
# Without this, the backfill route is disabled (returns 403).
ADMIN_BACKFILL_SECRET=

# ── Stripe (optional — required for subscription features) ───────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
